# =============================================================================
# agent_bridge – Example Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Lines starting with # are comments and are ignored.
#
# IMPORTANT: Never commit your real .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Host and port for the FastAPI / uvicorn server.
HOST=0.0.0.0
PORT=8000

# Logging verbosity: debug | info | warning | error | critical
LOG_LEVEL=info

# A random secret used to authenticate requests to protected endpoints.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_TOKEN=changeme


# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------

# Bot API token from @BotFather.  Required to enable the Telegram integration.
# TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrSTUvwxYZ

# Public HTTPS URL where Telegram will deliver webhook updates.
# Must be reachable from the internet. Use a service like ngrok for local dev.
# TELEGRAM_WEBHOOK_URL=https://your-domain.example.com/telegram/webhook

# Comma-separated list of Telegram user IDs that are allowed to interact with
# the bot. Leave empty to allow all users (NOT recommended for production).
# TELEGRAM_ALLOWED_USERS=111111111,222222222


# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------

# Bot token from the Discord Developer Portal.
# Required to enable the Discord integration.
# DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Comma-separated list of Discord user IDs allowed to send commands.
# Leave empty to allow all users (NOT recommended for production).
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432

# Comma-separated list of Discord guild (server) IDs where the bot is active.
# Leave empty to allow all guilds the bot is a member of.
# DISCORD_ALLOWED_GUILDS=


# -----------------------------------------------------------------------------
# AI Backend
# -----------------------------------------------------------------------------

# Base URL of the AI backend.
#   Ollama (default, local):  http://localhost:11434
#   OpenAI:                   https://api.openai.com
#   Any OpenAI-compatible:    https://api.together.xyz  (for example)
AI_BACKEND_URL=http://localhost:11434

# Backend type: "ollama" or "openai".
# Use "openai" for any OpenAI-compatible API (Together AI, Groq, LM Studio, etc.)
AI_BACKEND_TYPE=ollama

# API key for the AI backend.
#   - Required when AI_BACKEND_TYPE=openai.
#   - Optional (or empty) when using Ollama.
# AI_API_KEY=sk-your-openai-api-key-here

# Name of the model to use for completions.
#   Ollama examples:  llama3, codellama, mistral, deepseek-coder
#   OpenAI examples:  gpt-4o, gpt-4-turbo, gpt-3.5-turbo
AI_MODEL=llama3

# Maximum tokens to generate in a single response.
AI_MAX_TOKENS=4096

# Sampling temperature (0.0 = deterministic, 1.0 = creative).
# Lower values produce more consistent code.
AI_TEMPERATURE=0.2

# Timeout in seconds for AI backend HTTP requests.
AI_TIMEOUT_SECONDS=120.0

# System prompt prepended to every AI request.
# AI_SYSTEM_PROMPT=You are an expert AI coding assistant. Provide clear, concise, and correct code and explanations. Format code in fenced code blocks with the appropriate language tag.


# -----------------------------------------------------------------------------
# Task Queue
# -----------------------------------------------------------------------------

# Maximum number of AI tasks allowed to run concurrently.
MAX_CONCURRENT_TASKS=3

# Maximum time in seconds before a running task is cancelled.
TASK_TIMEOUT_SECONDS=300.0


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Path to the SQLite database file.
# Use ":memory:" for ephemeral in-memory storage (useful for testing).
DATABASE_URL=agent_bridge.db


# -----------------------------------------------------------------------------
# Webhook Callbacks (optional)
# -----------------------------------------------------------------------------

# If set, agent_bridge will POST the task completion payload to this URL.
# CALLBACK_URL=https://your-webhook-receiver.example.com/task-complete

# Optional secret sent in the X-Callback-Secret header so your receiver can
# verify that the request originated from agent_bridge.
# CALLBACK_SECRET=another-random-secret
